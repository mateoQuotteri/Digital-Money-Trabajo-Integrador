            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"cardId\": {{cardId}},\n  \"amount\": -100\n}"
            },
            "url": {
              "raw": "{{base_url}}/accounts/{{accountId}}/transferences",
              "host": ["{{base_url}}"],
              "path": ["accounts", "{{accountId}}", "transferences"]
            }
          }
        },
        {
          "name": "TC-S3-014 — POST /accounts/{id}/transferences — 404 tarjeta inexistente",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 404', function() { pm.response.to.have.status(404); });"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
