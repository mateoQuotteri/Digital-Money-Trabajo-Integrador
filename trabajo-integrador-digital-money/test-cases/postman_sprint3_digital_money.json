              "host": ["{{base_url}}"],
              "path": ["accounts", "{{accountId}}", "transferences"]
            }
          }
        },
        {
          "name": "TC-S3-015 — POST /accounts/{id}/transferences — 403 cuenta ajena",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 403', function() { pm.response.to.have.status(403); });"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
