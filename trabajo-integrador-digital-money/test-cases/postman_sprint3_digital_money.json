            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"cardId\": {{cardId}},\n  \"amount\": 100\n}"
            },
            "url": {
              "raw": "{{base_url}}/accounts/9999/transferences",
              "host": ["{{base_url}}"],
              "path": ["accounts", "9999", "transferences"]
            }
          }
        },
        {
          "name": "TC-S3-016 — Verificar saldo actualizado tras ingreso",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function() { pm.response.to.have.status(200); });",
                  "var data = pm.response.json();",
                  "pm.test('Saldo es mayor a cero', function() { pm.expect(parseFloat(data.saldo)).to.be.above(0); });",
                  "console.log('Saldo actual:', data.saldo);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/accounts/{{accountId}}",
              "host": ["{{base_url}}"],
              "path": ["accounts", "{{accountId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "5 — Flujo Completo (Workflow)",
      "item": [
        {
          "name": "FLOW-01 — Ingresar dinero y verificar en actividad",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201 - Transferencia creada', function() { pm.response.to.have.status(201); });",
                  "var data = pm.response.json();",
                  "pm.collectionVariables.set('transferId', data.id);",
                  "console.log('Transfer ID guardado para verificar en actividad:', data.id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"cardId\": {{cardId}},\n  \"amount\": 1000.00\n}"
            },
            "url": {
              "raw": "{{base_url}}/accounts/{{accountId}}/transferences",
              "host": ["{{base_url}}"],
              "path": ["accounts", "{{accountId}}", "transferences"]
            }
          }
        },
        {
          "name": "FLOW-02 — Verificar que aparece en listado de actividad",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function() { pm.response.to.have.status(200); });",
                  "var data = pm.response.json();",
                  "var transferId = parseInt(pm.collectionVariables.get('transferId'));",
                  "pm.test('La transferencia aparece en actividad', function() {",
                  "    var found = data.some(function(t) { return t.id === transferId; });",
                  "    pm.expect(found).to.be.true;",
                  "});",
                  "pm.test('Primera actividad es la mas reciente', function() {",
                  "    pm.expect(data[0].id).to.eql(transferId);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/accounts/{{accountId}}/activity",
              "host": ["{{base_url}}"],
              "path": ["accounts", "{{accountId}}", "activity"]
            }
          }
        },
        {
          "name": "FLOW-03 — Consultar detalle de la actividad recién creada",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function() { pm.response.to.have.status(200); });",
                  "var data = pm.response.json();",
                  "var transferId = parseInt(pm.collectionVariables.get('transferId'));",
                  "pm.test('ID coincide', function() { pm.expect(data.id).to.eql(transferId); });",
                  "pm.test('Monto correcto', function() { pm.expect(parseFloat(data.monto)).to.eql(1000.00); });",
                  "pm.test('Tipo CREDITO', function() { pm.expect(data.tipo).to.eql('CREDITO'); });",
                  "pm.test('Descripcion menciona tarjeta', function() { pm.expect(data.descripcion).to.include('tarjeta'); });"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/accounts/{{accountId}}/activity/{{transferId}}",
              "host": ["{{base_url}}"],
              "path": ["accounts", "{{accountId}}", "activity", "{{transferId}}"]
            }
          }
        }
      ]
    }
  ]
}
