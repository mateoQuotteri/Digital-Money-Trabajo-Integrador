{
  "info": {
    "name": "Digital Money House — Sprint 4",
    "_postman_id": "sprint4-digital-money-house",
    "description": "Colección de pruebas para Sprint 4: Transferencia de dinero a CBU/CVU/alias y listado de últimos destinatarios.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url",       "value": "http://localhost:8080", "type": "string" },
    { "key": "token",          "value": "",                      "type": "string" },
    { "key": "accountId",      "value": "",                      "type": "string" },
    { "key": "accountIdB",     "value": "",                      "type": "string" },
    { "key": "cvuDestino",     "value": "",                      "type": "string" },
    { "key": "aliasDestino",   "value": "",                      "type": "string" },
    { "key": "transferenciaId","value": "",                      "type": "string" },
    { "key": "cardId",         "value": "",                      "type": "string" }
  ],
  "item": [
    {
      "name": "0 — Setup (Login)",
      "item": [
        {
          "name": "POST /users/login — Usuario A",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.token) {",
                  "    pm.collectionVariables.set('token', json.token);",
                  "    console.log('Token guardado:', json.token);",
                  "}",
                  "if (json.accountId) {",
                  "    pm.collectionVariables.set('accountId', json.accountId);",
                  "    console.log('AccountId guardado:', json.accountId);",
                  "}",
                  "pm.test('Status 200', function() { pm.response.to.have.status(200); });",
                  "pm.test('Token presente', function() { pm.expect(json.token).to.be.a('string'); });"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"usuarioa@test.com\",\n  \"password\": \"Test1234!\"\n}"
            },
            "url": { "raw": "{{base_url}}/users/login", "host": ["{{base_url}}"], "path": ["users", "login"] }
          }
        },
        {
          "name": "GET /accounts/{id} — Verificar saldo inicial",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function() { pm.response.to.have.status(200); });",
                  "var json = pm.response.json();",
                  "pm.test('Tiene campo saldo', function() { pm.expect(json.saldo).to.exist; });",
                  "console.log('Saldo inicial de A:', json.saldo);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/accounts/{{accountId}}", "host": ["{{base_url}}"], "path": ["accounts", "{{accountId}}"] }
          }
        }
      ]
    },
    {
      "name": "1 — Ingreso de saldo previo (POST /deposits)",
      "item": [
        {
          "name": "POST /accounts/{id}/deposits — Cargar saldo desde tarjeta",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', function() { pm.response.to.have.status(201); });",
                  "var json = pm.response.json();",
                  "pm.test('Tipo CREDITO', function() { pm.expect(json.tipo).to.eql('CREDITO'); });",
                  "pm.test('Monto correcto', function() { pm.expect(json.monto).to.eql(1000); });",
                  "pm.test('Tiene id', function() { pm.expect(json.id).to.be.a('number'); });"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"cardId\": {{cardId}},\n  \"amount\": 1000\n}"
            },
            "url": { "raw": "{{base_url}}/accounts/{{accountId}}/deposits", "host": ["{{base_url}}"], "path": ["accounts", "{{accountId}}", "deposits"] }
          }
        }
      ]
    },
