    {
      "name": "3 — POST /transferences — Realizar transferencia (happy paths)",
      "item": [
        {
          "name": "TC-S4-007 — POST /transferences — Transferencia exitosa por CVU",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK', function() { pm.response.to.have.status(200); });",
                  "var json = pm.response.json();",
                  "pm.test('Tipo DEBITO', function() { pm.expect(json.tipo).to.eql('DEBITO'); });",
                  "pm.test('Monto correcto', function() { pm.expect(json.monto).to.eql(300); });",
                  "pm.test('Tiene id', function() { pm.expect(json.id).to.be.a('number'); });",
                  "pm.test('Tiene descripcion', function() { pm.expect(json.descripcion).to.be.a('string'); });",
                  "pm.test('Tiene fecha', function() { pm.expect(json.fecha).to.exist; });",
                  "if (json.id) { pm.collectionVariables.set('transferenciaId', json.id); }"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
